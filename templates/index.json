        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"ecom-band\"><div class=\"ecom-hero__glow\" style=\"width:400px;height:400px;filter:blur(140px)\"></div><div class=\"ecom-band__inner\"><div style=\"display:grid;gap:2.5rem\" class=\"ecom-whyus__grid\"><div><div style=\"font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#E25D54;margin-bottom:.75rem\">Why Ecommerized Shop</div><h2>A shop run by people who pack their own orders.</h2><p style=\"color:rgba(255,255,255,.60);margin-top:1rem;font-size:1rem\">Every product is something our agency team uses on real client packing benches. We don&rsquo;t carry SKUs we wouldn&rsquo;t recommend.</p></div><div style=\"display:grid;grid-template-columns:repeat(2,1fr);gap:1rem\" class=\"ecom-whyus__tiles\"><div class=\"ecom-tile\"><div class=\"ecom-tile__icon\">&#9889;</div><div class=\"ecom-tile__title\">Same-day dispatch</div><div class=\"ecom-tile__body\">Orders before 2pm Dubai time ship the same business day.</div></div><div class=\"ecom-tile\"><div class=\"ecom-tile__icon\">&#128230;</div><div class=\"ecom-tile__title\">Hand-picked stock</div><div class=\"ecom-tile__body\">Tested in the field by an ecommerce agency, not drop-shipped.</div></div><div class=\"ecom-tile\"><div class=\"ecom-tile__icon\">&#128737;</div><div class=\"ecom-tile__title\">Secure &amp; local</div><div class=\"ecom-tile__body\">UAE-VAT paid, Shopify-hosted checkout, PCI-compliant.</div></div><div class=\"ecom-tile\"><div class=\"ecom-tile__icon\">&#128172;</div><div class=\"ecom-tile__title\">Real WhatsApp support</div><div class=\"ecom-tile__body\">A human on WhatsApp within minutes, six days a week.</div></div></div></div></div></div><style>@media(min-width:1024px){.ecom-whyus__grid{grid-template-columns:1fr 2fr}}</style>"
