        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"ecom-section\"><div style=\"border-radius:24px;background:linear-gradient(135deg,#fff,#F9FAFB);border:1px solid #F3F4F6;padding:2rem;display:grid;gap:2rem;align-items:center\" class=\"ecom-finalcta\"><div><div style=\"font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#E25D54;margin-bottom:.5rem\">Not sure what you need?</div><h2 style=\"font-size:1.875rem;font-weight:800;color:#0B0F1A;margin:0;letter-spacing:-.02em\">Let us help you pick.</h2><p style=\"color:#4B5563;margin-top:.75rem;font-size:1rem;line-height:1.6\">Tell us what you ship and how often. We&rsquo;ll recommend the printer, labels, and packaging that&rsquo;ll fit your bench &mdash; no upsell, just a straight answer.</p></div><div style=\"display:flex;gap:.75rem;flex-wrap:wrap\"><a class=\"ecom-btn\" style=\"background:#25D366;box-shadow:none\" href=\"https://wa.me/971585788586\" target=\"_blank\" rel=\"noopener\">Chat on WhatsApp</a><a class=\"ecom-btn\" href=\"/collections/all\">Browse all products &rarr;</a></div></div></div><style>@media(min-width:1024px){.ecom-finalcta{grid-template-columns:1fr 1fr;padding:3rem}}</style>"
      }
