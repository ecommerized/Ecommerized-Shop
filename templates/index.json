    "testimonials": {
      "type": "custom-liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div style=\"background:#F9FAFB;border-top:1px solid #F3F4F6;border-bottom:1px solid #F3F4F6\"><div class=\"ecom-section\" style=\"padding-top:3.5rem;padding-bottom:3.5rem\"><div style=\"text-align:center;max-width:42rem;margin:0 auto 2.5rem\"><div style=\"font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#E25D54;margin-bottom:.75rem\">Trusted by UAE sellers</div><h2 style=\"font-size:1.875rem;font-weight:800;color:#0B0F1A;margin:0;letter-spacing:-.02em\">Small businesses ship with us every day.</h2></div><div style=\"display:grid;grid-template-columns:1fr;gap:1.25rem\" class=\"ecom-tst-grid\"><div style=\"padding:1.5rem;border-radius:16px;background:#fff;border:1px solid #F3F4F6\"><div style=\"color:#FBBF24;font-size:.9rem\">★★★★★</div><p style=\"font-size:.875rem;color:#374151;line-height:1.6;margin:.75rem 0 0\">“We ordered before lunch and the boxes were on our packing bench by 4pm. It changed how we run mornings.”</p><div style=\"display:flex;align-items:center;gap:.75rem;margin-top:1.25rem\"><div style=\"height:2.5rem;width:2.5rem;border-radius:9999px;background:linear-gradient(135deg,#E25D54,#F97316);color:#fff;font-size:.75rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0\">MA</div><div><div style=\"font-size:.875rem;font-weight:700;color:#0B0F1A\">Mariam Al Suwaidi</div><div style=\"font-size:.75rem;color:#6B7280\">Founder · Halia Studio · Dubai, UAE</div></div></div></div><div style=\"padding:1.5rem;border-radius:16px;background:#fff;border:1px solid #F3F4F6\"><div style=\"color:#FBBF24;font-size:.9rem\">★★★★★</div><p style=\"font-size:.875rem;color:#374151;line-height:1.6;margin:.75rem 0 0\">“Six packing stations, one bulk order, no follow-up emails. They make ops boring — in the best way.”</p><div style=\"display:flex;align-items:center;gap:.75rem;margin-top:1.25rem\"><div style=\"height:2.5rem;width:2.5rem;border-radius:9999px;background:linear-gradient(135deg,#E25D54,#F97316);color:#fff;font-size:.75rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0\">KR</div><div><div style=\"font-size:.875rem;font-weight:700;color:#0B0F1A\">Khalid Rashed</div><div style=\"font-size:.75rem;color:#6B7280\">Operations · Souq the Stack · Abu Dhabi, UAE</div></div></div></div><div style=\"padding:1.5rem;border-radius:16px;background:#fff;border:1px solid #F3F4F6\"><div style=\"color:#FBBF24;font-size:.9rem\">★★★★★</div><p style=\"font-size:.875rem;color:#374151;line-height:1.6;margin:.75rem 0 0\">“I order 4 mailers at a time and get treated like I ordered 400. Their WhatsApp support is the fastest I’ve dealt with.”</p><div style=\"display:flex;align-items:center;gap:.75rem;margin-top:1.25rem\"><div style=\"height:2.5rem;width:2.5rem;border-radius:9999px;background:linear-gradient(135deg,#E25D54,#F97316);color:#fff;font-size:.75rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0\">SM</div><div><div style=\"font-size:.875rem;font-weight:700;color:#0B0F1A\">Sara Mansour</div><div style=\"font-size:.75rem;color:#6B7280\">Owner · Bambino Books · Sharjah, UAE</div></div></div></div></div></div></div><style>@media(min-width:768px){.ecom-tst-grid{grid-template-columns:repeat(3,1fr)}}</style>"
