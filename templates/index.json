        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"ecom-hero\"><div class=\"ecom-hero__glow\"></div><div class=\"ecom-hero__inner\"><div style=\"display:grid;gap:2.5rem;align-items:center\" class=\"ecom-hero__grid\"><div><span class=\"ecom-hero__eyebrow\">UAE&rsquo;s ecommerce shop &middot; Ships from Dubai</span><h1>Ship faster.<span class=\"ecom-hero__accent\">Sell smarter.</span></h1><p>Printers, labels, packaging and POS &mdash; hand-picked for UAE sellers. Same-day dispatch from Dubai.</p><div style=\"display:flex;gap:.75rem;flex-wrap:wrap\"><a class=\"ecom-btn\" href=\"/collections/all\">Shop all products &rarr;</a><a class=\"ecom-btn\" style=\"background:rgba(255,255,255,.06);box-shadow:none\" href=\"https://wa.me/971585788586\" target=\"_blank\" rel=\"noopener\">Chat on WhatsApp</a></div><div style=\"display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1.5rem\"><span style=\"display:inline-flex;align-items:center;gap:.375rem;padding:.375rem .75rem;border-radius:9999px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);font-size:12px;font-weight:600;color:#fff\">&#9733; Free shipping over AED 200</span><span style=\"display:inline-flex;align-items:center;gap:.375rem;padding:.375rem .75rem;border-radius:9999px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);font-size:12px;font-weight:600;color:#fff\">Same-day dispatch from Dubai</span></div></div><div class=\"ecom-hero__media\" style=\"position:relative;min-height:340px\">{%- assign hp = collections.all.products -%}{%- for p in hp limit: 3 -%}<div style=\"position:absolute;background:#fff;border-radius:16px;box-shadow:0 25px 50px -12px rgba(0,0,0,.5);padding:1.25rem;{% cycle 'top:0;left:6%;width:14rem;height:14rem;transform:rotate(-6deg);z-index:30', 'top:18%;right:6%;width:12rem;height:12rem;transform:rotate(8deg);z-index:20', 'bottom:4%;left:24%;width:13rem;height:13rem;transform:rotate(3deg);z-index:10' %}\"><img src=\"{{ p.featured_image | image_url: width: 400 }}\" alt=\"{{ p.title | escape }}\" loading=\"lazy\" style=\"width:100%;height:100%;object-fit:contain\"></div>{%- endfor -%}<div style=\"position:absolute;top:6%;right:30%;background:rgba(255,255,255,.95);backdrop-filter:blur(8px);border-radius:9999px;padding:.375rem .75rem;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#0B0F1A;box-shadow:0 10px 15px -3px rgba(0,0,0,.2);z-index:40\"><span style=\"color:#E25D54\">●</span> Ships in 24h</div><div style=\"position:absolute;bottom:14%;right:12%;background:rgba(255,255,255,.95);backdrop-filter:blur(8px);border-radius:9999px;padding:.375rem .75rem;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#0B0F1A;box-shadow:0 10px 15px -3px rgba(0,0,0,.2);z-index:40\">Free over AED 200</div></div></div></div></div><style>@media(min-width:1024px){.ecom-hero__grid{grid-template-columns:1fr 1fr}}@media(max-width:1023px){.ecom-hero__media{display:none}}</style>"
      }
    },
